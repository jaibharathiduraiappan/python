class Solution:
    def generateString(self, str1: str, str2: str) -> str:
        n, m = len(str1), len(str2)
        total_len = n + m - 1
        res = [None] * total_len
        
        # 1. Apply 'T' constraints
        for i in range(n):
            if str1[i] == 'T':
                for k in range(m):
                    if res[i + k] is not None and res[i + k] != str2[k]:
                        return ""
                    res[i + k] = str2[k]
        
        # 2. Track empty slots and matching characters for 'F' constraints
        empty_count = [0] * n
        match_count = [0] * n
        for i in range(n):
            if str1[i] == 'F':
                for k in range(m):
                    if res[i + k] is None:
                        empty_count[i] += 1
                    elif res[i + k] == str2[k]:
                        match_count[i] += 1
                
                # If an 'F' range is already fully filled and matches str2
                if empty_count[i] == 0 and match_count[i] == m:
                    return ""
        
        # 3. Fill the gaps greedily from left to right
        for j in range(total_len):
            if res[j] is not None:
                continue
            
            # Find characters that would violate an 'F' constraint
            forbidden_mask = 0
            start_i = max(0, j - m + 1)
            end_i = min(n - 1, j)
            
            for i in range(start_i, end_i + 1):
                if str1[i] == 'F':
                    # If this index j is the LAST empty slot for this 'F' range
                    # and every other character in the range already matches str2
                    if empty_count[i] == 1 and match_count[i] == m - 1:
                        forbidden_char = str2[j - i]
                        forbidden_mask |= (1 << (ord(forbidden_char) - ord('a')))
            
            # Pick the smallest available character (lexicographical requirement)
            for bit in range(26):
                if not (forbidden_mask & (1 << bit)):
                    res[j] = chr(ord('a') + bit)
                    break
            
            # Update trackers for all 'F' constraints covering this index j
            for i in range(start_i, end_i + 1):
                if str1[i] == 'F':
                    empty_count[i] -= 1
                    if res[j] == str2[j - i]:
                        match_count[i] += 1
                        
        return "".join(res)
